 PROMOTIONS = {
     "BUY2GET50": "buy_2_get_50",
 }
 
 
+def _eligible_units(items: list[dict]) -> list[float]:
+    units: list[float] = []
+    for item in items:
+        if not item.get("eligible", False):
+            continue
+        if item.get("clearance", False):
+            continue
+
+        quantity = int(item.get("quantity", 1) or 0)
+        price = float(item.get("price", 0.0))
+        if quantity > 0:
+            units.extend([price] * quantity)
+    return units
+
+
+def _buy2get50_discount(items: list[dict]) -> float:
+    units = sorted(_eligible_units(items))
+    groups = len(units) // 3
+    discount = 0.0
+
+    for i in range(groups):
+        cheapest = units[i * 3]
+        discount += cheapest * 0.5
+
+    return discount
+
+
 def promotion_discount(items: list[dict], promotion_code: str | None) -> float:
